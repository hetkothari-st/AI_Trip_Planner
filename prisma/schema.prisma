// AI Trip Planner data model.
// SQLite for local dev; switch `provider`/`DATABASE_URL` to Postgres for production.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A trip draft. No auth in the MVP — a trip is identified by its id (stored client-side).
model Trip {
  id          String   @id @default(cuid())
  destination String
  region      String?
  // Journey routing (Phases 8–9)
  startStopId String?
  endStopId   String?
  optimized   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stops TripStop[]
}

// A selected place/city on the trip. Ordered for the roadmap.
model TripStop {
  id         String  @id @default(cuid())
  tripId     String
  trip       Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name       String
  category   String? // which category bucket it was picked from
  lat        Float
  lng        Float
  order      Int     @default(0)
  days       Int     @default(1)
  // JSON blobs filled in by later phases
  miniItinerary String? // Phase 5
  notes         String?

  spots           Spot[]
  hotelSelection  HotelSelection?
  costItems       CostItem[]
  activities      Activity[]

  @@index([tripId])
}

// Recommended spots within a city (Phase 5).
model Spot {
  id          String   @id @default(cuid())
  tripStopId  String
  tripStop    TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  durationMin Int?
  category    String? // sightseeing | food | activity
  lat         Float?
  lng         Float?

  @@index([tripStopId])
}

// Hotel chosen for a city (Phase 6).
model HotelSelection {
  id            String   @id @default(cuid())
  tripStopId    String   @unique
  tripStop      TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  name          String
  stars         Int?
  pricePerNight Float?
  currency      String   @default("INR")
  amenities     String? // JSON array
  deepLinks     String? // JSON map of site -> url
  bestPriceSite String?
}

// Real-time cost calculator line items (Phase 7).
model CostItem {
  id         String   @id @default(cuid())
  tripStopId String?
  tripStop   TripStop? @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  label      String
  category   String   // hotel | travel | activity | food | misc
  amount     Float
  currency   String   @default("INR")

  @@index([tripStopId])
}

// ── Auth.js (NextAuth) models ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hash for the credentials provider
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Bucket list / travel log — places the user has already visited. Scoped to a per-device
// clientId when anonymous; linked to a userId once the user signs in (optional auth).
model VisitedPlace {
  id          String   @id
  clientId    String
  userId      String?
  name        String
  destination String
  regionName  String?
  lat         Float?
  lng         Float?
  photoUrl    String?
  startDate   String?
  endDate     String?
  budget      Float?
  activities  String? // JSON array of activity tags
  rating      Int?
  notes       String?
  companions  Int?
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

// Selected activities (Phase 10).
model Activity {
  id          String   @id @default(cuid())
  tripStopId  String
  tripStop    TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  name        String
  provider    String?
  description String?
  price       Float?

  @@index([tripStopId])
}
