# ─── AI Trip Planner environment ──────────────────────────────────────────────
# The app runs fully in MOCK MODE with none of these set. Add keys to enable the
# corresponding real provider; each one degrades gracefully when its key is absent.

# Database (SQLite for local dev; swap to a Postgres URL for production)
DATABASE_URL="file:./dev.db"

# LLM — Anthropic Claude (region/category/place AI). Without it, AI uses seeded mocks.
ANTHROPIC_API_KEY=

# Maps & routing are KEY-LESS: MapLibre + OpenFreeMap tiles + OSRM routing.
# No token, account, or card required — nothing to set here.

# Multi-source research connectors (Phase 3). Any subset may be set.
TAVILY_API_KEY=
BRAVE_API_KEY=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Images (Phase 3 banners). Falls back to Wikimedia / placeholders without a key.
UNSPLASH_ACCESS_KEY=

# Hotels (Phase 6 — not used yet)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Auth (optional sign-in for the travel log). The app works anonymously without these.
# AUTH_SECRET is required for auth to work — generate with: openssl rand -base64 32
AUTH_SECRET=
# Google sign-in is optional; the button only appears when BOTH are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
